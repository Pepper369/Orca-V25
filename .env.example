# ============================================
# ORCA FINANCIAL Dashboard - Environment Config
# ============================================

# PostgreSQL connection string
# For local development with Docker PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# For production (Vercel + Neon/Supabase):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# Cron secret for /api/cron/hourly-update (required in production)
CRON_SECRET=replace-with-a-long-random-secret

# Auto-update settings
MIN_UPDATE_INTERVAL_MINUTES=50
PG_POOL_MAX=5
